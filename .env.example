# QueryWeaver example environment file
# Copy this to `.env` and edit values before running the app or the Docker image:
#
#   cp .env.example .env
#   # edit .env
#
# Minimal required variables for a basic run (these are left uncommented below):
# - FASTAPI_SECRET_KEY  (REQUIRED)
# - FALKORDB_URL       (REQUIRED) — preferred single connection string for FalkorDB
#
# Optional (commented) variables are provided as examples; uncomment and set them
# only if you need the functionality (OAuth, AI keys, local host/port overrides, etc.).

# -----------------------------
# Application / Server settings
# -----------------------------
# REQUIRED: secret used by FastAPI session middleware — change this before running in production
FASTAPI_SECRET_KEY=your_super_secret_key_here

# Optional: enable debug/reload when running the app directly
# FASTAPI_DEBUG=False

# Optional: set application environment (development, staging, production)
# Default: development
# APP_ENV=development

# General prefix for graph names used for Demo Graphs
# GENERAL_PREFIX=your_general_prefix_here

# Optional: allow OAuth over HTTP in development (disable in production)
# OAUTHLIB_INSECURE_TRANSPORT=1

# -----------------------------
# FalkorDB connection (REQUIRED / preferred)
# -----------------------------
# Preferred: single connection URL. Edit to point at your FalkorDB/Redis instance.
# Example: redis://localhost:6379/0
FALKORDB_URL=redis://localhost:6379/0  # REQUIRED - change to your FalkorDB URL

# Optional: separate host/port settings for local testing (only used if FALKORDB_URL is not set)
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379

# -----------------------------
# Optional API / secret tokens
# -----------------------------
# API token for internal API access (optional)
# SECRET_TOKEN=your_secret_token
# SECRET_TOKEN_ERP=your_erp_token

# -----------------------------
# AI / LLM configuration (optional)
# -----------------------------
# QueryWeaver supports three LLM providers: Azure OpenAI, OpenAI, and DeepSeek
# Configuration priority: User Config (web UI) > Environment Variables > System Defaults

# Option 1: Azure OpenAI (default if all three variables are set)
# AZURE_API_KEY=your_azure_api_key
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2023-05-15

# Option 2: OpenAI (direct API)
# OPENAI_API_KEY=your_openai_api_key

# Option 3: DeepSeek (cost-effective Chinese LLM, 90% cheaper than OpenAI)
# 获取 API Key: https://platform.deepseek.com/
# 1. 注册账号（支持中国手机号）
# 2. 进入 API Keys 页面
# 3. 创建新的 API Key
# 4. 复制 API Key（以 sk- 开头）
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com  # Optional, uses default if not set
# DEEPSEEK_COMPLETION_MODEL=deepseek-chat      # Optional: deepseek-chat or deepseek-coder
# DEEPSEEK_EMBEDDING_MODEL=text-embedding-ada-002  # Optional: embedding model

# Encryption key for secure API key storage (when using web UI configuration)
# Generate a secure 32-byte base64-encoded key for production
# Example: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, a default key will be generated (NOT recommended for production)
# LLM_CONFIG_ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# Optional: override default model names from api/config.py
# COMPLETION_MODEL=azure/gpt-4.1
# EMBEDDING_MODEL=azure/text-embedding-ada-002

# -----------------------------
# OAuth configuration (optional — uncomment to enable login flows)
# -----------------------------
# Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# WeChat OAuth (微信登录)
# 配置说明：
# 1. 在微信开放平台 (https://open.weixin.qq.com/) 创建网站应用
# 2. 配置授权回调域名为你的应用域名
# 3. 获取 AppID 和 AppSecret
# 4. 注意：需要已备案的域名才能使用微信登录
# WECHAT_APP_ID=wx1234567890abcdef
# WECHAT_APP_SECRET=your_wechat_app_secret

# WeCom OAuth (企业微信登录)
# 配置说明：
# 1. 在企业微信管理后台 (https://work.weixin.qq.com/) 创建自建应用
# 2. 配置可信域名为你的应用域名
# 3. 获取 CorpID (企业ID)、AgentID (应用ID) 和 CorpSecret (应用密钥)
# 4. 在应用管理中设置"网页授权及JS-SDK"的可信域名
# WECOM_CORP_ID=ww1234567890abcdef
# WECOM_AGENT_ID=1000001
# WECOM_CORP_SECRET=your_wecom_corp_secret

# If your OAuth app uses a different base URL than the request base (e.g., using 127.0.0.1 vs localhost)
# you can override the base used for building callback URLs. Example:
# OAUTH_BASE_URL=http://localhost:5000

# -----------------------------
# Email Configuration (optional - for sending invitation emails)
# -----------------------------
# MAIL_SERVER=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your_mail_username
# MAIL_PASSWORD=your_mail_password
# MAIL_DEFAULT_SENDER=noreply@yourdomain.com
# EMAIL_AUTH_ENABLED=false

# HTTP Connection Pool settings (optional)
# 连接池配置用于复用 HTTP 连接，减少网络开销
# 这些设置影响 LiteLLM 和其他 HTTP 客户端的连接管理
# HTTP 连接池大小（最大并发连接数）
# 默认值：100
# HTTP_POOL_SIZE=100

# 超出连接池大小时的额外连接数
# 默认值：10
# HTTP_MAX_OVERFLOW=10

# HTTP 请求超时时间（秒）
# 默认值：30.0
# HTTP_TIMEOUT=30.0

# Keep-Alive 连接超时时间（秒）
# 默认值：30.0
# HTTP_KEEPALIVE_TIMEOUT=30.0

# HTTP 代理设置（可选）
# 如果需要通过代理访问外部 API，配置以下变量
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8443
